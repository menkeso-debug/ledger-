# --- Core ---
DATABASE_URL=postgresql://user:pass@host:5432/ledger
PORT=3000
# 32-byte hex key for AES-256-GCM at-rest encryption of Plaid access tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LEDGER_ENCRYPTION_KEY=

# --- Plaid ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Public URL of the deployed service + /api/plaid/webhook (set once deployed on Railway)
PLAID_WEBHOOK_URL=
# JWT webhook verification (defaults: off in sandbox, on otherwise)
# PLAID_VERIFY_WEBHOOKS=true

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Advisory / analytics knobs ---
BRIEFING_CRON=30 7 * * *
LEDGER_TZ=America/New_York
MONTHLY_BUDGET=20000
MQD_TARGET=15000
MQD_TARGET_LABEL=Platinum

# --- Postgres TLS (only for external/public connections) ---
# PGSSL=true
